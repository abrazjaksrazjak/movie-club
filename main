    let movies = [];

    // Funkcje zapisu/odczytu z Firestore
    async function loadMoviesFromFirestore() {
        const snapshot = await db.collection("movies").get();
        if (snapshot.empty) {
            movies = JSON.parse(JSON.stringify(defaultMovies));
            await saveMoviesToFirestore();
        } else {
            movies = snapshot.docs.map(doc => doc.data());
        }
        // Po załadowaniu odśwież widok
        renderHome();
    }
    async function saveMoviesToFirestore() {
        const batch = db.batch();
        const snapshot = await db.collection("movies").get();
        snapshot.forEach(doc => batch.delete(doc.ref));
        movies.forEach(movie => {
            const docRef = db.collection("movies").doc(movie.id);
            batch.set(docRef, movie);
        });
        await batch.commit();
    }

    // Reszta funkcji (escape, renderStars, avgWeighted, parseDate, getNextMovie, renderHome, renderMovie, showArrows, next, prev, delMovie, modale) – IDENTYCZNA jak poprzednio, ale używamy saveMoviesToFirestore zamiast localStorage
    // Poniżej wklejam resztę skryptu (bez zmian, tylko wywołania saveMoviesToFirestore i loadMoviesFromFirestore)
    // UWAGA: ze względu na długość, wklejam pozostałą część kodu – ale ona jest identyczna jak w ostatniej wersji offline, zamieniam jedynie localStorage na Firebase.
    // Aby nie pominąć żadnej funkcji, doklejam cały dalszy kod.

    function escapeHtml(str) { if(!str) return ''; return str.replace(/[&<>]/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;'}[m])); }
    function renderStars(rating) {
        let starsHtml = `<span class="stars">`;
        for (let i = 1; i <= 5; i++) {
            if (i <= rating) {
                starsHtml += `<span class="star star-filled">★</span>`;
            } else {
                starsHtml += `<span class="star star-empty">★</span>`;
            }
        }
        starsHtml += `</span>`;
        return starsHtml;
    }
    function avgWeighted(movie) {
        let total = 0, weight = 0;
        movie.reviews.forEach(r => {
            if(!r.approved) return;
            let w = r.verified ? 2 : 1;
            total += r.stars * w;
            weight += w;
        });
        if(weight === 0) return '—';
        return (total / weight).toFixed(1);
    }
    function parseDate(dateStr) { let parts = dateStr.split('.'); return new Date(parts[2], parts[1]-1, parts[0]); }
    function getNextMovie() {
        let today = new Date(); today.setHours(0,0,0,0);
        let future = movies.filter(m => parseDate(m.date) >= today);
        if(future.length) return future.sort((a,b) => parseDate(a.date) - parseDate(b.date))[0];
        return movies.length ? movies.reduce((a,b) => parseDate(a.date) - parseDate(b.date) > 0 ? a : b) : null;
    }
    let current = 0, view = 'home';
    function renderHome() {
        const next = getNextMovie();
        const posterUrlNext = next && next.poster ? next.poster : '';
        const nextPosterHtml = posterUrlNext ? `<img class="poster" src="${escapeHtml(posterUrlNext)}" onerror="this.style.display='none'">` : '<div class="poster" style="background:#1a1a1a; display:flex; align-items:center; justify-content:center; color:#666;">🎬</div>';
        document.getElementById('mainContent').innerHTML = `
            <div class="home-container">
                <div class="next-movie-card" id="nextMovieCard">
                    ${nextPosterHtml}
                    <h2>NAJBLIŻSZY SEANS</h2>
                    <div class="title">${escapeHtml(next?.title || 'brak filmów')}</div>
                    <div class="date">${escapeHtml(next?.date || '')}</div>
                </div>
                <h3>RANKING</h3>
                <div class="ranking-list" id="rankingList"></div>
            </div>`;
        const rankingDiv = document.getElementById('rankingList');
        if(rankingDiv) {
            let sorted = [...movies].sort((a,b) => parseFloat(avgWeighted(b)) - parseFloat(avgWeighted(a)));
            rankingDiv.innerHTML = sorted.map((m, idx) => {
                const posterStyle = m.poster ? `background-image: url('${escapeHtml(m.poster)}'); background-size: cover;` : '';
                const rating = avgWeighted(m);
                const ratingText = rating !== '—' ? `${rating} ★` : '— ★';
                return `<div class="ranking-item" data-idx="${movies.indexOf(m)}" style="${posterStyle}"><span class="ranking-title">${idx+1}. ${escapeHtml(m.title)}</span><span class="ranking-rating">${ratingText}</span></div>`;
            }).join('');
            document.querySelectorAll('.ranking-item').forEach(el => {
                el.onclick = () => { current = parseInt(el.dataset.idx); view = 'movie'; renderMovie(); showArrows(true); };
            });
        }
        const nextCard = document.getElementById('nextMovieCard');
        if(nextCard && next) {
            nextCard.onclick = () => { 
                const idx = movies.findIndex(m => m.id === next.id);
                if(idx !== -1) { current = idx; view = 'movie'; renderMovie(); showArrows(true); }
            };
        }
        showArrows(false);
    }
    function renderMovie() {
        const m = movies[current];
        if(!m) { renderHome(); return; }
        const sortedReviews = [...m.reviews].sort((a,b) => {
            if(a.verified !== b.verified) return a.verified ? -1 : 1;
            if(a.approved !== b.approved) return a.approved ? -1 : 1;
            return b.timestamp - a.timestamp;
        });
        let revHtml = '';
        sortedReviews.forEach((r,i) => {
            const origIndex = m.reviews.findIndex(orig => orig.timestamp === r.timestamp && orig.author === r.author);
            const pendingClass = !r.approved ? 'pending' : '';
            const verifiedMark = r.verified ? '<span class="verified-check">✓</span>' : '';
            const actions = `
                <div class="review-actions">
                    ${!r.approved ? `<button class="review-action-btn approve-btn" data-idx="${origIndex}" title="Zatwierdź (admin)">✓</button>` : ''}
                    ${r.approved && !r.verified ? `<button class="review-action-btn verify-btn" data-idx="${origIndex}" title="JLL Verified (admin)">⭐</button>` : ''}
                    <button class="review-action-btn delete-review-btn" data-idx="${origIndex}" title="Usuń (admin)">✕</button>
                </div>
            `;
            revHtml += `
                <div class="review-row ${pendingClass}" data-idx="${origIndex}">
                    <div class="review-left">
                        <div style="display: flex; align-items: center; gap: 2px;">
                            ${renderStars(r.stars)}
                            ${verifiedMark}
                        </div>
                        <div class="review-author">${escapeHtml(r.author)}</div>
                    </div>
                    <div class="review-comment">${escapeHtml(r.comment)}</div>
                    ${actions}
                </div>
            `;
        });
        const sentHtml = m.sentimentalValue ? `<div class="sentimental">✨ ${escapeHtml(m.sentimentalValue)}</div>` : '';
        const posterUrl = m.poster && m.poster.trim() ? m.poster : '';
        const posterImg = posterUrl ? `<img class="poster-img" src="${escapeHtml(posterUrl)}" onerror="this.onerror=null; this.src='data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%221200%22%20height%3D%22300%22%3E%3Crect%20width%3D%221200%22%20height%3D%22300%22%20fill%3D%22%231a1a1a%22%2F%3E%3Ctext%20x%3D%2250%25%22%20y%3D%2250%25%22%20dominant-baseline%3D%22middle%22%20text-anchor%3D%22middle%22%20fill%3D%22%23888%22%20font-size%3D%2224%22%3Ebrak%20plakatu%3C%2Ftext%3E%3C%2Fsvg%3E'">` : `<div class="poster-img" style="background:#1a1a1a; display:flex; align-items:center; justify-content:center; color:#888;">🎬 brak plakatu</div>`;
        const avgVal = avgWeighted(m);
        const avgDisplay = avgVal !== '—' ? `${avgVal} ★` : '— ★';
        const slide = `
            <div class="carousel-container">
                <div class="slide">
                    <div class="poster-wrapper">${posterImg}<div class="movie-title-overlay">${escapeHtml(m.title)}</div><button class="edit-movie-btn" id="editBtn">✎</button></div>
                    <div class="movie-date">${escapeHtml(m.date)}</div>
                    <div class="reviews-grid" id="reviewsGrid">${revHtml}</div>
                    ${sentHtml}
                    <div class="add-review">
                        <div class="review-form-grid">
                            <div class="review-form-row">
                                <div class="review-form-left">
                                    <input type="text" id="reviewAuthor" placeholder="Imię" maxlength="20">
                                    <div class="rating-input" id="starSelector">
                                        ${[1,2,3,4,5].map(n => `<span class="star-select" data-value="${n}">★</span>`).join('')}
                                    </div>
                                </div>
                                <div class="review-form-middle">
                                    <textarea id="reviewComment" placeholder="Napisz kilka słów o filmie (Enter aby dodać)" maxlength="256"></textarea>
                                    <div class="avg-box" id="avgBox">${avgDisplay}</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>`;
        document.getElementById('mainContent').innerHTML = slide;
        document.querySelectorAll('.approve-btn').forEach(btn => {
            btn.onclick = () => {
                const idx = parseInt(btn.dataset.idx);
                const pwd = prompt("Hasło admina, aby zatwierdzić:");
                if(pwd === ADMIN_PASSWORD) {
                    movies[current].reviews[idx].approved = true;
                    movies[current].reviews[idx].timestamp = Date.now();
                    saveMoviesToFirestore().then(() => renderMovie());
                } else alert("Złe hasło");
            };
        });
        document.querySelectorAll('.verify-btn').forEach(btn => {
            btn.onclick = () => {
                const idx = parseInt(btn.dataset.idx);
                const pwd = prompt("Hasło admina, aby nadać JLL Verified:");
                if(pwd === ADMIN_PASSWORD) {
                    movies[current].reviews[idx].verified = true;
                    movies[current].reviews[idx].timestamp = Date.now();
                    saveMoviesToFirestore().then(() => renderMovie());
                } else alert("Złe hasło");
            };
        });
        document.querySelectorAll('.delete-review-btn').forEach(btn => {
            btn.onclick = () => {
                const idx = parseInt(btn.dataset.idx);
                const pwd = prompt("Hasło admina, aby usunąć recenzję:");
                if(pwd === ADMIN_PASSWORD) {
                    movies[current].reviews.splice(idx,1);
                    saveMoviesToFirestore().then(() => renderMovie());
                } else alert("Złe hasło");
            };
        });
        let selStars = 0;
        const starsSpans = document.querySelectorAll('#starSelector .star-select');
        starsSpans.forEach((s,i) => { s.onclick = () => { selStars = i+1; starsSpans.forEach((ss,j) => ss.classList.toggle('selected', j<=i)); }; });
        const textarea = document.getElementById('reviewComment');
        const authorInput = document.getElementById('reviewAuthor');
        function addPendingReview() {
            const a = authorInput.value.trim();
            const c = textarea.value.trim();
            if(!a) { alert("Podaj imię"); return; }
            if(!selStars) { alert("Wybierz gwiazdki"); return; }
            movies[current].reviews.push({
                author: a,
                stars: selStars,
                comment: c || "(bez komentarza)",
                approved: false,
                verified: false,
                timestamp: Date.now()
            });
            saveMoviesToFirestore().then(() => renderMovie());
            authorInput.value = '';
            textarea.value = '';
            selStars = 0;
            starsSpans.forEach(s => s.classList.remove('selected'));
        }
        textarea.addEventListener('keydown', (e) => {
            if(e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                addPendingReview();
            }
        });
        document.getElementById('editBtn').onclick = () => { document.getElementById('editTitle').value = m.title; document.getElementById('editPosterUrl').value = m.poster||''; document.getElementById('editSentimental').value = m.sentimentalValue||''; document.getElementById('editMovieModal').style.display = 'flex'; };
        document.getElementById('avgBox').onclick = () => { view = 'home'; renderHome(); };
    }
    function showArrows(show) { document.getElementById('prevArrow').style.display = show ? 'flex' : 'none'; document.getElementById('nextArrow').style.display = show ? 'flex' : 'none'; }
    function next() { if(view==='movie' && movies.length) { current = (current+1)%movies.length; renderMovie(); } }
    function prev() { if(view==='movie' && movies.length) { current = (current-1+movies.length)%movies.length; renderMovie(); } }
    function delMovie() { if(view!=='movie') return; if(prompt("Hasło admina, aby USUNĄĆ film:")===ADMIN_PASSWORD) { movies.splice(current,1); saveMoviesToFirestore().then(() => { if(movies.length===0) renderHome(); else { if(current>=movies.length) current=movies.length-1; renderMovie(); } }); } else alert("Złe hasło"); }

    // Obsługa modal (dodawanie filmu, edycja) – również z Firebase
    const addModal = document.getElementById('movieModal'), editModal = document.getElementById('editMovieModal');
    document.getElementById('openModalBtn').onclick = () => addModal.style.display = 'flex';
    document.getElementById('cancelModalBtn').onclick = () => addModal.style.display = 'none';
    document.getElementById('deleteMovieBtn').onclick = delMovie;
    document.getElementById('cancelEditBtn').onclick = () => editModal.style.display = 'none';
    window.onclick = (e) => { if(e.target===addModal) addModal.style.display='none'; if(e.target===editModal) editModal.style.display='none'; };
    document.getElementById('posterFile').onchange = (e) => { const f = e.target.files[0]; if(f && f.type.startsWith('image/')) { const r = new FileReader(); r.onload = (ev) => document.getElementById('newPosterUrl').value = ev.target.result; r.readAsDataURL(f); } };
    document.getElementById('editPosterFile').onchange = (e) => { const f = e.target.files[0]; if(f && f.type.startsWith('image/')) { const r = new FileReader(); r.onload = (ev) => document.getElementById('editPosterUrl').value = ev.target.result; r.readAsDataURL(f); } };
    document.getElementById('saveMovieBtn').onclick = () => { if(prompt("Hasło admina:")!==ADMIN_PASSWORD) { alert("Złe hasło"); return; } const t = document.getElementById('newTitle').value.trim(); if(!t) return alert("Tytuł wymagany"); movies.push({ id:Date.now(), date:document.getElementById('newDate').value.split('-').reverse().join('.'), title:t, poster:document.getElementById('newPosterUrl').value.trim(), reviews:[], sentimentalValue:document.getElementById('newSentimental').value.trim() }); saveMoviesToFirestore().then(() => { current=movies.length-1; view='movie'; renderMovie(); showArrows(true); addModal.style.display='none'; document.getElementById('newTitle').value=''; document.getElementById('newPosterUrl').value=''; document.getElementById('newSentimental').value=''; document.getElementById('posterFile').value=''; }); };
    document.getElementById('saveEditBtn').onclick = () => { if(prompt("Hasło admina:")!==ADMIN_PASSWORD) { alert("Złe hasło"); return; } const nt = document.getElementById('editTitle').value.trim(); if(!nt) return alert("Tytuł nie może być pusty"); movies[current].title = nt; movies[current].poster = document.getElementById('editPosterUrl').value.trim(); movies[current].sentimentalValue = document.getElementById('editSentimental').value.trim(); saveMoviesToFirestore().then(() => { if(view==='movie') renderMovie(); else renderHome(); editModal.style.display='none'; }); };
    document.getElementById('homeLogo').onclick = () => { view = 'home'; renderHome(); };
    document.getElementById('prevArrow').onclick = prev; document.getElementById('nextArrow').onclick = next;
    window.addEventListener('keydown', (e) => { if(view==='movie') { if(e.key==='ArrowLeft') prev(); if(e.key==='ArrowRight') next(); } });
    // Start
    loadMoviesFromFirestore();
</script>
</body>
</html>
